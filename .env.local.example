# Supabase — get these from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Gemini — generate at https://aistudio.google.com/app/apikey
# Keep this server-side only (no NEXT_PUBLIC_ prefix)
GEMINI_API_KEY=your-gemini-api-key-here

# Web Push (VAPID) — generate once with:
#   npx web-push generate-vapid-keys
# NEXT_PUBLIC_ key is sent to browsers; private key stays server-side only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
# Contact address shown in push requests (mailto: or https:)
VAPID_SUBJECT=mailto:admin@your-farm.example.com
